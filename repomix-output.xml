/** Create golfers with specific handicap indices */
function handicapGolfer(id: string, hcp: number): GroupingGolfer {
  return { profileId: id, teeTimePreference: 'no_preference', handicapIndex: hcp };
}

describe('Flight Foursomes', () => {
