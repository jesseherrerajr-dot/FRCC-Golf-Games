              (link.href === "/home" && pathname === "/profile");

        return (
          <Link
            key={link.href}
            href={link.href}
            className={`rounded-md px-3 py-2.5 transition-colors ${
              isActive
                ? "bg-navy-50 font-semibold text-navy-900"
